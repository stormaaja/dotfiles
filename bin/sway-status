#!/bin/bash

BRIGHTNESS_ICON="☼"
VOLUME_ICON="🔊"
MIC_ICON="🎤"
HEADPHONES_ICON_CONNECTED="🎧"
MUTED_ICON="🔇"
BATTERY_ICON_FULL="🔋"
BATTERY_ICON_EMPTY="🪫"
CHARGING_ICON="⚡"

HEADPHONES_ICON=""

STATUS_FOLDER=$HOME/.local/share/sway-status
STATUS_FILE="$STATUS_FOLDER/last.dat"

if [ ! -f $STATUS_FOLDER ]; then
	mkdir -p $STATUS_FOLDER
fi

BT_HEADSETS="WH-1000XM5|Jabra Elite 3"

STATUS_LINE=""

while true
do
  # Get brightness integer value
  BRIGHTNESS=$(light | awk '{print int($1+0.5)}')
  BLUETOOTH_DEVICES=$(bluetoothctl devices Connected)

  BLUETOOTH_HEADSETS_CONNECTED=$(echo $BLUETOOTH_DEVICES | grep -c -E "$BT_HEADSETS")
  if [ $BLUETOOTH_HEADSETS_CONNECTED -gt 0 ]; then
      HEADPHONES_ICON=$HEADPHONES_ICON_CONNECTED
  fi

  ENABLED=$(amixer get Master | grep 'Right:' | awk '{print $6}')
  if [ "$ENABLED" == "[off]" ]; then
      VOLUME_ICON=$MUTED_ICON
  fi

  MIC_ENABLED_ICON=""

  MIC_ENABLED=$(amixer get Capture | grep -E 'Right:|Mono:' | awk '{print $5}')
  if [ "$MIC_ENABLED" == "[on]" ]; then
      MIC_ENABLED_ICON=$MIC_ICON
  fi
  VOLUME=$(amixer get Master | grep 'Right:' | awk '{print $5}' | sed 's/[^0-9]*//g')

  DATE=$(date +'%Y-%m-%d %H:%M:%S')

  BATTERY=$(cat /sys/class/power_supply/BAT0/capacity)
  BATTERY_ICON=$BATTERY_ICON_FULL
  if [ $BATTERY -lt 20 ]; then
      BATTERY_ICON=$BATTERY_ICON_EMPTY
  fi

  BATTERY_STATUS=$(cat /sys/class/power_supply/BAT0/status)

  if [ "$BATTERY_STATUS" == "Charging" ]; then
      BATTERY_ICON=$CHARGING_ICON
  fi

  KEYBOARD_LAYOUT=$(swaymsg -t get_inputs | jq 'map(select(has("xkb_active_layout_name")))[0].xkb_active_layout_name' | sed 's/"//g')
  KEYBOARD_LAYOUT_ICON="🇺🇸"
  if [ "$KEYBOARD_LAYOUT" == "Finnish" ]; then
      KEYBOARD_LAYOUT_ICON="🇫🇮"
  fi

  PERFORMANCE_MODE_ICON=""

  PERFORMANCE_MODE=$(powerprofilesctl get)
  if [ "$PERFORMANCE_MODE" == "performance" ]; then
      PERFORMANCE_MODE_ICON="⹈"
  elif [ "$PERFORMANCE_MODE" == "balanced" ]; then
      PERFORMANCE_MODE_ICON="⹇"
  elif [ "$PERFORMANCE_MODE" == "power-saver" ]; then
      PERFORMANCE_MODE_ICON="⹅"
  fi

  STATUS_LINE="| $HEADPHONES_ICON $MIC_ENABLED_ICON $VOLUME_ICON $VOLUME | $BRIGHTNESS_ICON $BRIGHTNESS | $BATTERY_ICON $BATTERY $PERFORMANCE_MODE_ICON | $KEYBOARD_LAYOUT_ICON $DATE"

  echo $STATUS_LINE > $STATUS_FILE

  now_ns=$(date +%s%N)
  next_ns=$(( (now_ns/1000000000 + 1) * 1000000000 ))
  sleep_time=$(awk "BEGIN {print ($next_ns - $now_ns)/1000000000}")
  sleep "$sleep_time"
done

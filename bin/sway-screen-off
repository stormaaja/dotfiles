#!/bin/bash
# 1. Lock the screen
swaylock -f -c 000000 &
# 2. Give the lock 3 seconds to initialize
sleep 1
# 3. Turn off screens
swaymsg "output * dpms off"
# 4. Wait for ANY activity, then turn screens back on
swayidle -w \
    timeout 2 'true' \
    resume 'swaymsg "output * dpms on"; pkill -n swayidle'

